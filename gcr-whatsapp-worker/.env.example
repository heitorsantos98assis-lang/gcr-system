# Porta HTTP do servidor (Railway define automaticamente)
PORT=3000

# === Planilha Google Sheets ===
# ID da planilha GCR
SPREADSHEET_ID=1PW7-oGks8HT4d-Xb32uQou3KJc86JpQKeY4ogI-LqeM
# GID da aba "Métricas GCR" (resumo + acompanhamento diário + quebras)
METRICS_GID=1981009125
# GID da aba de leads brutos
LEADS_GID=0

# === Agendamento ===
# Cron no fuso TZ_CRON. Padrão: 06:00 todo dia
CRON_SCHEDULE=0 6 * * *
TZ_CRON=America/Sao_Paulo

# === Grupos do WhatsApp ===
# Use UMA das duas opções (ou ambas — IDs ganham prioridade).
#
# Opção A (RECOMENDADA): por nome de grupo. Resolução case-insensitive feita no momento do envio.
# Múltiplos nomes separados por vírgula.
TARGET_GROUP_NAMES=GESTÃO ANTONIO E CELSO
#
# Opção B: por ID @g.us (descoberto via GET /api/groups após conectar).
# Mais preciso, sobrevive a renomeações do grupo, mas exige passo manual extra.
# Se preenchido, ignora TARGET_GROUP_NAMES.
TARGET_GROUP_IDS=
#
# Se ambos vazios: envia para TODOS os grupos visíveis na conta (apenas para teste).

# === Sessão WhatsApp ===
# Path onde whatsapp-web.js grava credenciais. No Railway, monte volume em /data
# para persistir entre deploys (caso contrário, QR Code precisa ser reescaneado).
SESSION_DATA_PATH=/data/wwebjs_auth
